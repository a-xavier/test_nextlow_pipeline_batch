plugins {
        id 'nf-amazon' // Required for AWS Batch support
}

profiles {
    // Local execution profile
    local {
        // Still have aws to fetch the json and the files
        aws {
            profile = "perso"
        }

        process {
            executor = 'local'
        }

        wave {
            enabled = false
        }

        weblog {
            enabled = true
            url = 'http://localhost:3000/api/analysis_logs'
        }

        // Params 
        params.publishDir = 'results'
        params.reference_dir = "~/references/"
    }

    // AWS Batch execution profile
    aws {
        process {
            executor = 'awsbatch'
            conda = 'conda-forge::awscli'
            queue = 'nextflow-worker-queue-ec2'
            scratch = '/mnt/scratch' // mounter when creating the EC2 instance, hard coded in launch template
            containerOptions = "-v /mnt/references:/references"
        }

        aws {
            region = 'ap-southeast-2'
            batch {
                jobRole = System.getenv('BATCH_JOB_ROLE_ARN')
                executionRole = System.getenv('BATCH_EXECUTION_ROLE_ARN')
            }
        }
        wave {
            enabled = true
            strategy = ['conda', 'container']
        }


        // Params
        params.publishDir = "s3://portalseq/Analysis/${params.analysis_id}/results/"
        params.reference_dir = "references/" // this is the path within the container, mapped to /mnt/references on the host
        workDir = "s3://portalseq/Analysis/${params.analysis_id}/work/"
    }
}